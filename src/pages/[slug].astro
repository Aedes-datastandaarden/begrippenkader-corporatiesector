---
import allConcepts from '../../public/build/0.2/concepts.json';
import type { Concept } from '../lib/types';
import { conceptUrl } from '../lib/version';

export function getStaticPaths() {
  return (allConcepts as Concept[]).map((concept) => ({
    params: { slug: concept.slug },
    props: { slug: concept.slug },
  }));
}

const { slug } = Astro.props;
return Astro.redirect(conceptUrl(slug));
---
