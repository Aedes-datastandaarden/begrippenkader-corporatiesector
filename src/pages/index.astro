---
import Layout from '../layouts/Layout.astro';
import HomeContent from '../components/HomeContent';
import versions from '../../public/build/versions.json';
import scheme from '../../public/build/0.2/scheme.json';
import collections from '../../public/build/0.2/collections.json';
import allConcepts from '../../public/build/0.2/concepts.json';
---

<Layout title={scheme.title} description={scheme.description}>
  <HomeContent
    client:load
    defaultScheme={scheme}
    defaultCollections={collections}
    defaultConcepts={allConcepts}
    versionsManifest={versions}
  />
</Layout>
