---
import '../styles/global.css';
import VersionSelector from '../components/VersionSelector.astro';
import { buildAssetPath, pageUrl } from '../lib/version';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Begrippenkader Corporatiesector', description } = Astro.props;
const fullTitle = title === 'Begrippenkader Corporatiesector' ? title : `${title} — Begrippenkader Corporatiesector`;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? 'Publieke weergave van het Begrippenkader Corporatiesector (SKOS / NL-SBB).'} />
    <link rel="icon" type="image/svg+xml" href={buildAssetPath('favicon.svg')} />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a href="https://aedes.nl/" class="site-header__logo" target="_blank" rel="noopener noreferrer">
          <img src={buildAssetPath('aedes-logo.svg')} alt="Aedes" width="82" height="36" />
        </a>
        <a href={pageUrl()} class="site-header__title">Begrippenkader Corporatiesector</a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <span>
          <a href="https://www.aedesdatastandaarden.nl/" target="_blank" rel="noopener noreferrer">Aedes Datastandaarden</a>: Begrippenkader Corporatiesector
        </span>
        <VersionSelector />
      </div>
    </footer>
  </body>
</html>
