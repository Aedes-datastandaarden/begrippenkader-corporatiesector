---
import type { RelationRef } from '../lib/types';
import { pageUrl, withVersionParam } from '../lib/version';

interface Props {
  broader: RelationRef[];
  narrower: RelationRef[];
  related: RelationRef[];
  exactMatch: RelationRef[];
  closeMatch: RelationRef[];
  version?: string;
}

const { broader, narrower, related, exactMatch, closeMatch, version } = Astro.props;

function begripHref(slug: string) {
  const path = pageUrl('begrip', slug);
  return version ? withVersionParam(path, version) : path;
}

function renderInternal(refs: RelationRef[]) {
  return refs.filter((r) => r.internal);
}

function renderExternal(refs: RelationRef[]) {
  return refs.filter((r) => !r.internal);
}
---

{(broader.length > 0 || narrower.length > 0 || related.length > 0) && (
  <section class="field-block" aria-labelledby="relations-heading">
    <h2 id="relations-heading" class="field-block__label">Relaties</h2>

    {broader.length > 0 && (
      <div>
        <h3 class="relation-type">Breder begrip</h3>
        <ul class="concept-list">
          {renderInternal(broader).map((ref) => (
            <li>
              <a href={begripHref(ref.slug!)}>{ref.prefLabel}</a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {narrower.length > 0 && (
      <div>
        <h3 class="relation-type">Smaller begrip</h3>
        <ul class="concept-list">
          {renderInternal(narrower).map((ref) => (
            <li>
              <a href={begripHref(ref.slug!)}>{ref.prefLabel}</a>
            </li>
          ))}
        </ul>
      </div>
    )}

    {related.length > 0 && (
      <div>
        <h3 class="relation-type">Verwant begrip</h3>
        <ul class="concept-list">
          {renderInternal(related).map((ref) => (
            <li>
              <a href={begripHref(ref.slug!)}>{ref.prefLabel}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
)}

{exactMatch.length > 0 && (
  <section class="field-block" aria-labelledby="exact-heading">
    <h2 id="exact-heading" class="field-block__label">Overeenkomstig begrip (extern)</h2>
    <ul class="concept-list">
      {renderExternal(exactMatch).map((ref) => (
        <li>
          <a href={ref.uri} rel="noopener noreferrer" target="_blank">{ref.prefLabel}</a>
        </li>
      ))}
    </ul>
  </section>
)}

{closeMatch.length > 0 && (
  <section class="field-block" aria-labelledby="close-heading">
    <h2 id="close-heading" class="field-block__label">Verwant begrip (extern)</h2>
    <ul class="concept-list">
      {renderExternal(closeMatch).map((ref) => (
        <li>
          <a href={ref.uri} rel="noopener noreferrer" target="_blank">{ref.prefLabel}</a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .relation-type {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0.75rem 0 0.25rem;
  }
</style>
