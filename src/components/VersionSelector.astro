---
import versions from '../../public/build/versions.json';

const versionParam = Astro.url.searchParams.get('v');
const activeVersion = versionParam && versions.versions.some((v) => v.id === versionParam)
  ? versionParam
  : versions.latest;
---

<div class="version-selector">
  <label for="version-select" class="sr-only">Versie</label>
  <span aria-hidden="true">Versie:</span>
  <select id="version-select" data-latest={versions.latest}>
    {versions.versions.map((v) => (
      <option value={v.id} selected={v.id === activeVersion}>
        {v.id}{v.status ? ` (${v.status})` : ''}
      </option>
    ))}
  </select>
</div>

<script>
  const select = document.getElementById('version-select') as HTMLSelectElement | null;
  if (select) {
    const params = new URLSearchParams(window.location.search);
    const urlVersion = params.get('v');
    const stored = sessionStorage.getItem('skos-viewer-version');
    const latest = select.dataset.latest ?? '';
    const active = urlVersion ?? stored ?? latest;

    if (active) {
      select.value = active;
      if (urlVersion) {
        sessionStorage.setItem('skos-viewer-version', urlVersion);
      } else if (stored) {
        const url = new URL(window.location.href);
        url.searchParams.set('v', stored);
        window.history.replaceState({}, '', url.toString());
      }
    }

    select.addEventListener('change', () => {
      sessionStorage.setItem('skos-viewer-version', select.value);
      const url = new URL(window.location.href);
      url.searchParams.set('v', select.value);
      window.location.href = url.toString();
    });
  }
</script>

<style>
  .version-selector {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
  }

  select {
    font-size: inherit;
    padding: 0.125rem 0.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
  }
</style>
