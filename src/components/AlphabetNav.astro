---
interface Props {
  activeLetter?: string;
  version?: string;
}

const { activeLetter, version } = Astro.props;
import { pageUrl, withVersionParam } from '../lib/version';
const letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

function letterHref(letter: string) {
  const path = pageUrl('alfabet', letter.toLowerCase());
  return version ? withVersionParam(path, version) : path;
}
---

<nav class="alphabet-nav" aria-label="Alfabet-navigatie">
  {letters.map((letter) => (
    <a
      href={letterHref(letter)}
      aria-current={activeLetter?.toUpperCase() === letter ? 'page' : undefined}
    >
      {letter}
    </a>
  ))}
  <a
    href={letterHref('hash')}
    aria-current={activeLetter === '#' ? 'page' : undefined}
  >
    #
  </a>
</nav>
