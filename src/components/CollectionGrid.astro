---
import type { Collection } from '../lib/types';
import { pageUrl, withVersionParam } from '../lib/version';

interface Props {
  collections: Collection[];
  version?: string;
}

const { collections, version } = Astro.props;
---

<section aria-labelledby="collections-heading">
  <h2 id="collections-heading">Thematische collecties</h2>
  <div class="card-grid">
    {collections.map((collection) => (
      <a class="card" href={version ? withVersionParam(pageUrl('collectie', collection.slug), version) : pageUrl('collectie', collection.slug)}>
        <p class="card__title">{collection.prefLabel}</p>
        <p class="card__meta">{collection.memberCount} begrippen</p>
      </a>
    ))}
  </div>
</section>
